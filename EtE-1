Option Explicit

Sub ProcessSheet1_ExportToSheet2()
    '配置常量 放大批次上限避免单条文本拆分超限
    Const MAX_CHARS As Long = 50
    Const FULL_SPACE As String = "　"
    Const BLOCK_SIZE As Long = 200000 '放大至20万
    
    Dim srcWs As Worksheet, outWs As Worksheet
    Dim sourceArr As Variant
    Dim outputArr() As Variant
    Dim reg As Object
    Dim lastRow As Long
    Dim i As Long, j As Long, arrIdx As Long
    Dim rawTxt As String, cleanTxt As String, piece As String
    
    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    Application.EnableEvents = False
    
    '校验工作表
    On Error Resume Next
    Set srcWs = Worksheets("1")
    Set outWs = Worksheets("2")
    On Error GoTo 0
    
    If srcWs Is Nothing Then
        Call RestoreAppSetting
        MsgBox "缺少工作表【1】", vbCritical
        Exit Sub
    End If
    If outWs Is Nothing Then
        Call RestoreAppSetting
        MsgBox "缺少工作表【2】", vbCritical
        Exit Sub
    End If
    
    '清空输出表A列
    outWs.Columns("A").ClearContents
    outWs.Columns("A").NumberFormat = "@"
    outWs.Columns("A").WrapText = True
    
    Set reg = CreateObject("VBScript.RegExp")
    reg.Global = False
    reg.Pattern = "^[ 　]+"
    
    lastRow = srcWs.Cells(srcWs.Rows.Count, "A").End(xlUp).Row
    If lastRow < 1 Then
        Call RestoreAppSetting
        MsgBox "工作表1 A列无数据", vbExclamation
        Exit Sub
    End If
    sourceArr = srcWs.Range("A1:A" & lastRow).Value
    
    ReDim outputArr(1 To BLOCK_SIZE, 1 To 1)
    arrIdx = 1
    
    For i = 1 To UBound(sourceArr)
        rawTxt = CStr(sourceArr(i, 1))
        cleanTxt = reg.Replace(rawTxt, "")
        If Len(cleanTxt) > 0 Then
            cleanTxt = FULL_SPACE & cleanTxt
        End If
        cleanTxt = Replace(cleanTxt, "=", "")
        cleanTxt = CleanIllegalChars(cleanTxt)
        
        If Len(cleanTxt) = 0 Then GoTo NextLine
        
        For j = 1 To Len(cleanTxt) Step MAX_CHARS
            piece = Mid(cleanTxt, j, MAX_CHARS)
            outputArr(arrIdx, 1) = piece
            arrIdx = arrIdx + 1
            
            '达到批次上限立刻写入，重置数组
            If arrIdx > BLOCK_SIZE Then
                Call WriteBlock(outputArr, arrIdx - 1, outWs)
                arrIdx = 1
                Erase outputArr
                ReDim outputArr(1 To BLOCK_SIZE, 1 To 1)
            End If
        Next j
NextLine:
    Next i
    
    '仅存在有效数据才写入剩余块，避免validRows=0越界
    If arrIdx - 1 >= 1 Then
        Call WriteBlock(outputArr, arrIdx - 1, outWs)
    End If
    
    Call RestoreAppSetting
    MsgBox "处理完成，数据输出至工作表2 A列", vbInformation
End Sub

'批量写入，增加边界保护
Private Sub WriteBlock(ByRef blockArr As Variant, ByVal validRows As Long, targetWs As Worksheet)
    If validRows < 1 Then Exit Sub
    ReDim Preserve blockArr(1 To validRows, 1 To 1)
    Dim writeStart As Long
    writeStart = targetWs.Cells(targetWs.Rows.Count, "A").End(xlUp).Row + 1
    If writeStart = 0 Then writeStart = 1
    targetWs.Range("A" & writeStart).Resize(validRows, 1).Value = blockArr
End Sub

Private Sub RestoreAppSetting()
    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
End Sub

Private Function CleanIllegalChars(ByVal inputStr As String) As String
    Dim k As Long
    Dim charCode As Long
    Dim result As String
    result = ""
    For k = 1 To Len(inputStr)
        charCode = AscW(Mid(inputStr, k, 1))
        If (charCode >= 32 Or charCode = 13 Or charCode = 10) And Not (charCode >= &H200B And charCode <= &H200F) Then
            result = result & Mid(inputStr, k, 1)
        End If
    Next k
    CleanIllegalChars = result
End Function
