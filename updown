'=========自定义参数区=========
Const PWD_STR As String = "KEY123"
Const AUTO_CLEAR_MINS As Integer = 5
Const SOURCE_SHEET As String = "表3"
Const SOURCE_COL As String = "B"
Const TARGET_SHEET As String = "目标表"
Const TARGET_CELL As String = "D10"
Const START_READ_ROW As Long = 2
'=============================

Public TimerID As Date
Public ReadRow As Long

'1. 启动倒计时
Sub StartAutoCountDown()
    On Error Resume Next
    If TimerID > 0 Then
        Application.OnTime TimerID, "ClearTargetCell", , False
    End If
    TimerID = Now + TimeSerial(0, AUTO_CLEAR_MINS, 0)
    Application.OnTime TimerID, "ClearTargetCell"
End Sub

'2. 自动清空单元格
Sub ClearTargetCell()
    ThisWorkbook.Worksheets(TARGET_SHEET).Range(TARGET_CELL).ClearContents
    TimerID = 0
    MsgBox "超时自动清空，操作已失效", vbInformation
End Sub

'3. 关闭计时器
Sub StopTimerTask()
    On Error Resume Next
    If TimerID > 0 Then
        Application.OnTime TimerID, "ClearTargetCell", , False
    End If
End Sub

'4. 密码校验函数
Function CheckPassword() As Boolean
    Dim s As String
    s = InputBox("请输入授权字符：")
    If Trim(s) = PWD_STR Then
        CheckPassword = True
    Else
        MsgBox "字符错误", vbExclamation
        CheckPassword = False
    End If
End Function

'5. 执行复制粘贴
Sub CopyDataToTarget()
    Dim srcSht As Worksheet, tarSht As Worksheet
    Set srcSht = Sheets(SOURCE_SHEET)
    Set tarSht = Sheets(TARGET_SHEET)
    tarSht.Range(TARGET_CELL).Value = srcSht.Range(SOURCE_COL & ReadRow).Value
    Call StartAutoCountDown
End Sub

'=========无按钮，两个独立执行子程序=========
'【上一行】直接运行这个宏
Sub PrevRow()
    If Not CheckPassword Then Exit Sub
    If TimerID = 0 Then
        MsgBox "已超时，请重新开始", vbCritical
        Exit Sub
    End If
    
    If ReadRow = 0 Then ReadRow = START_READ_ROW
    ReadRow = ReadRow - 1
    
    If ReadRow < START_READ_ROW Then
        MsgBox "已是首行", vbInformation
        ReadRow = START_READ_ROW
        Exit Sub
    End If
    
    Call CopyDataToTarget
End Sub

'【下一行】直接运行这个宏
Sub NextRow()
    If Not CheckPassword Then Exit Sub
    If TimerID = 0 Then
        MsgBox "已超时，请重新开始", vbCritical
        Exit Sub
    End If
    
    Dim lastRow As Long
    If ReadRow = 0 Then ReadRow = START_READ_ROW
    
    lastRow = Sheets(SOURCE_SHEET).Cells(Rows.Count, SOURCE_COL).End(xlUp).Row
    ReadRow = ReadRow + 1
    
    If ReadRow > lastRow Then
        MsgBox "已是末行", vbInformation
        ReadRow = lastRow
        Exit Sub
    End If
    
    Call CopyDataToTarget
End Sub
